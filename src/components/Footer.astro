---
const LOGO = "https://d2xsxph8kpxj0f.cloudfront.net/310519663540279873/mqBaZEe8cowVKqLebSdcGQ/hawley-logo-modern-K7nsMoUjXa4vQaiXbz97jj.webp";

const services = [
  { label: "Kitchen Remodeling", href: "/kitchen-remodeling-st-petersburg/" },
  { label: "Bathroom Remodeling", href: "/bathroom-remodeling-st-petersburg/" },
  { label: "Trex Deck Builder", href: "/trex-deck-builder-tampa-bay/" },
  { label: "Sunroom & Florida Room", href: "/sunroom-florida-room-contractor/" },
  { label: "ADU & In-Law Suite", href: "/adu-in-law-suite-builder/" },
  { label: "Home Additions", href: "/services/home-additions" },
  { label: "Full Home Remodels", href: "/services/full-home-remodels" },
  { label: "Outdoor Living Spaces", href: "/services/outdoor-living" },
  { label: "Patios", href: "/services/patios" },
  { label: "Windows & Doors", href: "/services/windows-doors" },
  { label: "Custom Cabinetry", href: "/services/custom-cabinetry" },
];

const areas = [
  { label: "Tampa", href: "/areas/tampa" },
  { label: "St. Petersburg", href: "/areas/st-petersburg" },
  { label: "Clearwater", href: "/areas/clearwater" },
  { label: "Bradenton", href: null },
  { label: "Tarpon Springs", href: null },
  { label: "Sarasota", href: null },
  { label: "Wesley Chapel", href: null },
];
---
<footer style="background-color:var(--navy);" class="text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex flex-col leading-none mb-6">
          <span class="text-2xl font-bold tracking-wide" style="font-family:'Playfair Display',serif;">HAWLEY</span>
          <span class="text-[9px] font-semibold tracking-[0.18em] uppercase" style="color:var(--gold);font-family:'DM Sans',sans-serif;">Construction Co.</span>
        </div>
        <p class="text-sm leading-relaxed mb-6" style="color:oklch(0.65 0.01 250);font-family:'DM Sans',sans-serif;">Tampa Bay's trusted home remodeling contractor. Licensed, insured, and committed to quality craftsmanship since 2019.</p>
        <div class="flex flex-col gap-3">
          <a href="tel:7046191480" class="flex items-center gap-2 text-sm font-semibold" style="color:var(--gold);font-family:'DM Sans',sans-serif;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.09a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 17.5z"></path></svg>
            (704) 619-1480
          </a>
          <a href="mailto:landon@hawleyconstruction.co" class="flex items-center gap-2 text-sm" style="color:oklch(0.65 0.01 250);font-family:'DM Sans',sans-serif;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            landon@hawleyconstruction.co
          </a>
          <div class="flex items-start gap-2 text-sm" style="color:oklch(0.65 0.01 250);font-family:'DM Sans',sans-serif;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            316 11th Ave NE, St. Petersburg, FL 33701
          </div>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest mb-5" style="color:var(--gold);font-family:'DM Sans',sans-serif;">Services</h3>
        <ul class="flex flex-col gap-2">
          {services.map(s => (
            <li><a href={s.href} class="text-sm transition-colors hover:text-white" style="color:oklch(0.65 0.01 250);font-family:'DM Sans',sans-serif;">{s.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Service Areas -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest mb-5" style="color:var(--gold);font-family:'DM Sans',sans-serif;">Service Areas</h3>
        <ul class="flex flex-col gap-2">
          {areas.map(a => (
            <li>
              {a.href ? (
                <a href={a.href} class="text-sm transition-colors hover:text-white" style="color:oklch(0.65 0.01 250);font-family:'DM Sans',sans-serif;">{a.label}</a>
              ) : (
                <span class="text-sm" style="color:oklch(0.65 0.01 250);font-family:'DM Sans',sans-serif;">{a.label}</span>
              )}
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest mb-5" style="color:var(--gold);font-family:'DM Sans',sans-serif;">Quick Links</h3>
        <ul class="flex flex-col gap-2 mb-8">
          {[
            { label: 'About Us', href: '/#about' },
            { label: 'Our Work', href: '/our-work' },
            { label: 'Blog', href: '/blog' },
            { label: 'FAQ', href: '/faq' },
            { label: 'Contact', href: '/contact' },
            { label: 'Free Estimate', href: '/contact' },
          ].map(l => (
            <li><a href={l.href} class="text-sm transition-colors hover:text-white" style="color:oklch(0.65 0.01 250);font-family:'DM Sans',sans-serif;">{l.label}</a></li>
          ))}
        </ul>
        <a href="/contact" class="btn-gold text-xs">Get Free Estimate</a>
      </div>
    </div>

    <div class="border-t mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4" style="border-color:oklch(0.28 0.008 250);">
      <p class="text-xs" style="color:oklch(0.5 0.01 250);font-family:'DM Sans',sans-serif;">© {new Date().getFullYear()} Hawley Construction Co. All rights reserved. | Licensed General Contractor — State of Florida</p>
      <div class="flex gap-6">
        <a href="/sitemap.xml" class="text-xs transition-colors hover:text-white" style="color:oklch(0.5 0.01 250);font-family:'DM Sans',sans-serif;">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
