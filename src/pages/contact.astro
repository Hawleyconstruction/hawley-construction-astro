---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact Hawley Construction Co.",
    "url": "https://hawleyconstruction.co/contact",
    "mainEntity": {
      "@type": "GeneralContractor",
      "@id": "https://hawleyconstruction.co",
      "name": "Hawley Construction Co.",
      "telephone": "+17046191480",
      "email": "landon@hawleyconstruction.co",
      "address": {"@type": "PostalAddress", "addressLocality": "St. Petersburg", "addressRegion": "FL", "addressCountry": "US"},
      "url": "https://hawleyconstruction.co"
    }
  }
];
---
<Layout
  title="Contact Hawley Construction Co. | Free Estimate | Tampa Bay"
  description="Contact Hawley Construction Co. for a free estimate on your remodeling or construction project in Tampa Bay. Call (704) 619-1480 or submit our online form."
  canonical="https://hawleyconstruction.co/contact"
  schema={schemaData}
>
  <Navbar />
  <section class="pt-28 pb-12 md:pt-36 md:pb-16" style="background-color:var(--navy);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-semibold uppercase tracking-[0.2em] mb-3 block" style="color:var(--gold);font-family:'DM Sans',sans-serif;">Get in Touch</span>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4" style="font-family:'Playfair Display',serif;">Request a Free Estimate</h1>
      <p class="text-lg" style="color:rgba(255,255,255,0.75);font-family:'DM Sans',sans-serif;">We respond to all inquiries within 24 hours. No obligation, no pressure.</p>
    </div>
  </section>
  <section class="py-16 md:py-24" style="background-color:var(--cream);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Contact Info -->
        <div class="lg:col-span-2">
          <span class="section-divider"></span>
          <h2 class="text-2xl font-bold mb-6" style="color:var(--navy2);">Hawley Construction Co.</h2>
          <div class="flex flex-col gap-6">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color:var(--gold);font-family:'DM Sans',sans-serif;">Phone</p>
              <a href="tel:7046191480" class="text-lg font-semibold" style="color:var(--navy2);font-family:'DM Sans',sans-serif;">(704) 619-1480</a>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color:var(--gold);font-family:'DM Sans',sans-serif;">Email</p>
              <a href="mailto:landon@hawleyconstruction.co" class="text-base" style="color:var(--navy2);font-family:'DM Sans',sans-serif;">landon@hawleyconstruction.co</a>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color:var(--gold);font-family:'DM Sans',sans-serif;">Service Area</p>
              <p class="text-base" style="color:var(--muted);font-family:'DM Sans',sans-serif;">St. Petersburg, Tampa, Clearwater, Largo, Dunedin, Safety Harbor, and all of Tampa Bay</p>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color:var(--gold);font-family:'DM Sans',sans-serif;">Hours</p>
              <p class="text-base" style="color:var(--muted);font-family:'DM Sans',sans-serif;">Monday – Friday: 7am – 6pm<br />Saturday: 8am – 2pm<br />Sunday: Closed</p>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color:var(--gold);font-family:'DM Sans',sans-serif;">License</p>
              <p class="text-base" style="color:var(--muted);font-family:'DM Sans',sans-serif;">Florida State Certified General Contractor<br />Licensed, Bonded &amp; Insured</p>
            </div>
          </div>
        </div>
        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <div class="bg-white p-8 md:p-10 shadow-sm" style="border-radius:2px;">
            <h2 class="text-2xl font-bold mb-2" style="color:var(--navy2);">Tell Us About Your Project</h2>
            <p class="text-sm mb-8" style="color:var(--muted);font-family:'DM Sans',sans-serif;">Fill out the form below and Landon will personally reach out within 24 hours to schedule your free in-home estimate.</p>
            <form id="contact-form" action="https://formspree.io/f/xredrbrg" method="POST" class="flex flex-col gap-5">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label class="text-xs font-semibold uppercase tracking-widest mb-1 block" style="color:var(--muted);font-family:'DM Sans',sans-serif;">First Name *</label>
                  <input class="form-input" type="text" name="first_name" placeholder="John" required />
                </div>
                <div>
                  <label class="text-xs font-semibold uppercase tracking-widest mb-1 block" style="color:var(--muted);font-family:'DM Sans',sans-serif;">Last Name *</label>
                  <input class="form-input" type="text" name="last_name" placeholder="Smith" required />
                </div>
              </div>
              <div>
                <label class="text-xs font-semibold uppercase tracking-widest mb-1 block" style="color:var(--muted);font-family:'DM Sans',sans-serif;">Email Address *</label>
                <input class="form-input" type="email" name="email" placeholder="john@example.com" required />
              </div>
              <div>
                <label class="text-xs font-semibold uppercase tracking-widest mb-1 block" style="color:var(--muted);font-family:'DM Sans',sans-serif;">Phone Number</label>
                <input class="form-input" type="tel" name="phone" placeholder="(727) 555-0100" />
              </div>
              <div>
                <label class="text-xs font-semibold uppercase tracking-widest mb-1 block" style="color:var(--muted);font-family:'DM Sans',sans-serif;">Service Needed</label>
                <select class="form-input" name="service">
                  <option value="">Select a service...</option>
                  <option value="Kitchen Remodeling">Kitchen Remodeling</option>
                  <option value="Bathroom Remodeling">Bathroom Remodeling</option>
                  <option value="Home Addition">Home Addition</option>
                  <option value="Trex Deck">Trex Deck</option>
                  <option value="Sunroom / Florida Room">Sunroom / Florida Room</option>
                  <option value="ADU / In-Law Suite">ADU / In-Law Suite</option>
                  <option value="Full Home Remodel">Full Home Remodel</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <div>
                <label class="text-xs font-semibold uppercase tracking-widest mb-1 block" style="color:var(--muted);font-family:'DM Sans',sans-serif;">Project Description *</label>
                <textarea class="form-input" name="message" rows="5" placeholder="Describe your project, timeline, and any specific requirements..." required></textarea>
              </div>
              <button type="submit" class="btn-gold w-full text-center py-4">Send Message &amp; Request Estimate</button>
            </form>
            <p id="form-success" class="hidden text-base mt-6 text-center font-semibold p-4" style="color:oklch(0.45 0.15 145);background-color:oklch(0.97 0.03 145);border-radius:2px;">Thank you! Landon will be in touch within 24 hours to schedule your free estimate.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
<script>
document.getElementById('contact-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const form = e.target as HTMLFormElement;
  const data = new FormData(form);
  const res = await fetch(form.action, { method: 'POST', body: data, headers: { 'Accept': 'application/json' } });
  if (res.ok) {
    form.style.display = 'none';
    document.getElementById('form-success')?.classList.remove('hidden');
    if (typeof gtag !== 'undefined') {
      gtag('event', 'conversion', { 'send_to': 'AW-18172396876/cPy9CKLmgrQcEMyKo91D', 'value': 100.0, 'currency': 'USD' });
      gtag('event', 'generate_lead', { 'currency': 'USD', 'value': 100.0 });
    }
  }
});
</script>
