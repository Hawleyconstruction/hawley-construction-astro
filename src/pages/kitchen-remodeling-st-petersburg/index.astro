---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Kitchen Remodeling St. Petersburg FL",
    "description": "Full kitchen remodeling services in St. Petersburg FL. Custom cabinetry, countertops, open-concept conversions. Licensed, insured, fixed-price quotes.",
    "provider": {"@type": "GeneralContractor", "@id": "https://hawleyconstruction.co", "name": "Hawley Construction Co.", "telephone": "+17046191480", "url": "https://hawleyconstruction.co"},
    "areaServed": [{"@type": "City", "name": "St. Petersburg"}, {"@type": "City", "name": "Tampa"}, {"@type": "City", "name": "Clearwater"}],
    "url": "https://hawleyconstruction.co/kitchen-remodeling-st-petersburg/",
    "serviceType": "Kitchen Remodeling",
    "offers": {"@type": "Offer", "priceRange": "$30,000 - $150,000+", "priceCurrency": "USD"}
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type": "Question", "name": "How long does a kitchen remodel take in St. Petersburg?", "acceptedAnswer": {"@type": "Answer", "text": "Most full kitchen remodels run 6-10 weeks from demolition to final walkthrough. Cabinet lead times can push this 1-2 weeks if you choose custom."}},
      {"@type": "Question", "name": "Do you handle permits and HOA approvals?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. We pull every required permit through Pinellas County or the City of St. Petersburg and coordinate any HOA approvals."}},
      {"@type": "Question", "name": "Are your quotes fixed or estimates?", "acceptedAnswer": {"@type": "Answer", "text": "Fixed. Once we sign a contract, the price does not change unless you request a scope change in writing."}},
      {"@type": "Question", "name": "Can you remove a load-bearing wall?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. It requires structural engineering, a beam install, and permits, all of which we handle."}}
    ]
  }
];
const HERO = "https://d2xsxph8kpxj0f.cloudfront.net/310519663540279873/mqBaZEe8cowVKqLebSdcGQ/hawley-hero-kitchen-mSpoc3xtKks8iMHpTCvAxs.webp";
const KIT_BEFORE = "https://d2xsxph8kpxj0f.cloudfront.net/310519663540279873/mqBaZEe8cowVKqLebSdcGQ/kitchen-before-gnpMvGCrqpA7wDknZQaauG.webp";
const KIT_AFTER = "https://d2xsxph8kpxj0f.cloudfront.net/310519663540279873/mqBaZEe8cowVKqLebSdcGQ/kitchen-after-hsVXguHfNLPDyGVXHRHCyx.webp";
const faqs = [
  { q: "How long does a kitchen remodel take in St. Petersburg?", a: "Most full kitchen remodels run 6-10 weeks from demolition to final walkthrough. Cabinet lead times can push this 1-2 weeks if you choose custom." },
  { q: "Do you handle permits and HOA approvals?", a: "Yes. We pull every required permit through Pinellas County or the City of St. Petersburg and coordinate any HOA approvals." },
  { q: "Can my family live in the house during the remodel?", a: "For most kitchen projects, yes. We set up a temporary kitchenette in another part of the home." },
  { q: "Are your quotes fixed or estimates?", a: "Fixed. Once we sign a contract, the price does not change unless you request a scope change in writing." },
  { q: "What brands and materials do you work with?", a: "Cabinetry from KraftMaid, Wellborn, and custom local shops. Quartz from Cambria, Caesarstone, and Silestone. Appliances from KitchenAid, Wolf, Sub-Zero, GE Profile, Bosch, and Thermador." },
  { q: "Can you remove a load-bearing wall?", a: "Yes. It requires structural engineering, a beam install, and permits, all of which we handle." },
];
const benefits = ["Custom cabinetry and storage solutions", "Quartz, granite and marble countertops", "Island design and layout optimization", "Backsplash tile and flooring", "Lighting design and electrical upgrades", "Appliance installation", "Open-concept conversions", "Permit handling included"];
---
<Layout
  title="Kitchen Remodeling St. Petersburg FL | Hawley Construction Co."
  description="Trusted kitchen remodelers serving St. Petersburg and Tampa Bay. Fixed-price quotes, licensed and insured, free in-home estimate. Call (704) 619-1480."
  canonical="https://hawleyconstruction.co/kitchen-remodeling-st-petersburg/"
  schema={schemaData}
  ogImage={HERO}
>
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-28 pb-20 md:pt-36 md:pb-28" style="background-color:var(--navy);">
    <div class="absolute inset-0 overflow-hidden">
      <img src={HERO} alt="Kitchen remodeling St. Petersburg FL" class="w-full h-full object-cover opacity-35" loading="eager" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <nav class="flex items-center gap-2 text-xs mb-6" style="color:rgba(255,255,255,0.6);font-family:'DM Sans',sans-serif;" aria-label="Breadcrumb">
          <a href="/" style="color:rgba(255,255,255,0.6);">Home</a><span>/</span>
          <a href="/services" style="color:rgba(255,255,255,0.6);">Services</a><span>/</span>
          <span style="color:var(--gold);">Kitchen Remodeling</span>
        </nav>
        <span class="text-xs font-semibold uppercase tracking-[0.2em] mb-3 block" style="color:var(--gold);font-family:'DM Sans',sans-serif;">St. Petersburg, FL</span>
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight" style="font-family:'Playfair Display',serif;">Kitchen Remodeling St. Petersburg FL</h1>
        <p class="text-lg mb-8" style="color:rgba(255,255,255,0.8);font-family:'DM Sans',sans-serif;">Tampa Bay most trusted kitchen remodeler. Fixed-price quotes, licensed and insured, personally overseen by owner Landon Hawley on every project.</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="btn-gold text-center">Get Free Estimate</a>
          <a href="tel:7046191480" class="btn-outline-light text-center">Call (704) 619-1480</a>
        </div>
      </div>
    </div>
  </section>

  <!-- BEFORE / AFTER -->
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:var(--muted);font-family:'DM Sans',sans-serif;">Before</p>
          <img src={KIT_BEFORE} alt="Kitchen before remodel" class="w-full h-72 object-cover" style="border-radius:2px;" loading="lazy" />
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:var(--gold);font-family:'DM Sans',sans-serif;">After</p>
          <img src={KIT_AFTER} alt="Kitchen after remodel" class="w-full h-72 object-cover" style="border-radius:2px;" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- CONTENT + FORM -->
  <section class="py-16 md:py-24" style="background-color:var(--cream);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <span class="section-divider"></span>
          <h2 class="text-3xl font-bold mb-6" style="color:var(--navy2);">St. Petersburg Kitchen Remodeling Experts</h2>
          <p class="text-base leading-relaxed mb-6" style="color:var(--muted);font-family:'DM Sans',sans-serif;">Hawley Construction Co. has been transforming kitchens across St. Petersburg, Tampa, and Clearwater since 2019. Whether you want a cosmetic refresh or a full structural renovation, we deliver exceptional craftsmanship at a fixed price with no surprises.</p>
          <p class="text-base leading-relaxed mb-8" style="color:var(--muted);font-family:'DM Sans',sans-serif;">Every kitchen remodel includes our signature 6-step process: free in-home consultation, design and material selection, detailed fixed-price proposal, permit acquisition, construction with daily site cleanup, and a final walkthrough with a one-year warranty on our work.</p>

          <h3 class="text-2xl font-bold mb-4" style="color:var(--navy2);">What Is Included</h3>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10">
            {benefits.map(b => (
              <li class="flex items-start gap-2 text-sm" style="color:var(--muted);font-family:'DM Sans',sans-serif;">
                <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 mt-1.5" style="background-color:var(--gold);display:inline-block;"></span>
                {b}
              </li>
            ))}
          </ul>

          <h3 class="text-2xl font-bold mb-4" style="color:var(--navy2);">Investment Guide</h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
            <div class="p-6 shadow-sm bg-white" style="border-radius:2px;">
              <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:var(--gold);font-family:'DM Sans',sans-serif;">Refresh</p>
              <p class="text-3xl font-bold mb-2" style="color:var(--navy2);font-family:'Playfair Display',serif;">$30K-$50K</p>
              <p class="text-sm" style="color:var(--muted);font-family:'DM Sans',sans-serif;">New counters, backsplash, paint, lighting, and select cabinet updates.</p>
            </div>
            <div class="p-6 shadow-sm" style="border-radius:2px;background-color:var(--navy);">
              <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:var(--gold);font-family:'DM Sans',sans-serif;">Mid-Range Remodel</p>
              <p class="text-3xl font-bold mb-2 text-white" style="font-family:'Playfair Display',serif;">$50K-$100K</p>
              <p class="text-sm" style="color:rgba(255,255,255,0.7);font-family:'DM Sans',sans-serif;">Full cabinet replacement, new appliances, flooring, layout adjustments.</p>
            </div>
            <div class="p-6 shadow-sm bg-white" style="border-radius:2px;">
              <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:var(--gold);font-family:'DM Sans',sans-serif;">Premium Remodel</p>
              <p class="text-3xl font-bold mb-2" style="color:var(--navy2);font-family:'Playfair Display',serif;">$100K+</p>
              <p class="text-sm" style="color:var(--muted);font-family:'DM Sans',sans-serif;">Custom cabinetry, structural changes, high-end appliances, designer finishes.</p>
            </div>
          </div>

          <h3 class="text-2xl font-bold mb-4" style="color:var(--navy2);">Frequently Asked Questions</h3>
          <div class="mb-10" id="faq-container">
            {faqs.map((item, i) => (
              <div class="border-b py-5" style="border-color:oklch(0.88 0.01 250);">
                <button class="faq-btn w-full text-left flex items-center justify-between gap-4" data-idx={i}>
                  <span class="text-base font-semibold" style="color:var(--navy2);font-family:'DM Sans',sans-serif;">{item.q}</span>
                  <span class="text-xl font-light flex-shrink-0" style="color:var(--gold);">+</span>
                </button>
                <div class="faq-answer hidden mt-3">
                  <p class="text-sm leading-relaxed" style="color:var(--muted);font-family:'DM Sans',sans-serif;">{item.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- STICKY FORM -->
        <div class="lg:col-span-1">
          <div class="bg-white p-8 shadow-sm sticky top-24" style="border-radius:2px;">
            <h2 class="text-xl font-bold mb-2" style="color:var(--navy2);">Get a Free Estimate</h2>
            <p class="text-sm mb-6" style="color:var(--muted);font-family:'DM Sans',sans-serif;">We respond within 24 hours. No obligation.</p>
            <form id="seo-form" action="https://formspree.io/f/xredrbrg" method="POST" class="flex flex-col gap-4">
              <input type="hidden" name="service" value="Kitchen Remodeling" />
              <input class="form-input" type="text" name="name" placeholder="Your Name" required />
              <input class="form-input" type="email" name="email" placeholder="Email Address" required />
              <input class="form-input" type="tel" name="phone" placeholder="Phone Number" />
              <textarea class="form-input" name="message" rows="4" placeholder="Describe your project..."></textarea>
              <button type="submit" class="btn-gold w-full text-center">Send Message</button>
            </form>
            <p id="form-success" class="hidden text-sm mt-4 text-center font-semibold" style="color:oklch(0.55 0.15 145);">Thank you! We will be in touch within 24 hours.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16" style="background-color:var(--navy);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4" style="font-family:'Playfair Display',serif;">Ready to Transform Your Kitchen?</h2>
      <p class="mb-8" style="color:rgba(255,255,255,0.7);font-family:'DM Sans',sans-serif;">Call us or request a free estimate online. Serving St. Petersburg, Tampa, Clearwater, and all of Tampa Bay.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn-gold text-center">Get Free Estimate</a>
        <a href="tel:7046191480" class="btn-outline-light text-center">Call (704) 619-1480</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
<script>
document.getElementById('seo-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const form = e.target as HTMLFormElement;
  const data = new FormData(form);
  const res = await fetch(form.action, { method: 'POST', body: data, headers: { 'Accept': 'application/json' } });
  if (res.ok) {
    form.style.display = 'none';
    document.getElementById('form-success')?.classList.remove('hidden');
    if (typeof gtag !== 'undefined') {
      gtag('event', 'conversion', { 'send_to': 'AW-18172396876/cPy9CKLmgrQcEMyKo91D', 'value': 100.0, 'currency': 'USD' });
      gtag('event', 'generate_lead', { 'currency': 'USD', 'value': 100.0 });
    }
  }
});
document.querySelectorAll('.faq-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const answer = btn.nextElementSibling as HTMLElement;
    const icon = btn.querySelector('span:last-child') as HTMLElement;
    const isOpen = !answer.classList.contains('hidden');
    answer.classList.toggle('hidden', isOpen);
    icon.textContent = isOpen ? '+' : '\u2212';
  });
});
</script>
