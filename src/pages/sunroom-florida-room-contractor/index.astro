---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Sunroom and Florida Room Contractor Tampa Bay",
    "description": "Sunroom and Florida room additions in Tampa Bay. Three-season and four-season sunrooms, screened enclosures. Licensed, insured, fixed-price quotes.",
    "provider": {"@type": "GeneralContractor", "@id": "https://hawleyconstruction.co", "name": "Hawley Construction Co.", "telephone": "+17046191480", "url": "https://hawleyconstruction.co"},
    "areaServed": [{"@type": "City", "name": "Tampa"}, {"@type": "City", "name": "St. Petersburg"}, {"@type": "City", "name": "Clearwater"}],
    "url": "https://hawleyconstruction.co/sunroom-florida-room-contractor/",
    "serviceType": "Sunroom Construction",
    "offers": {"@type": "Offer", "priceRange": "$25,000 - $80,000+", "priceCurrency": "USD"}
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type": "Question", "name": "How much does a sunroom cost in Florida?", "acceptedAnswer": {"@type": "Answer", "text": "A sunroom addition in Florida costs between $25,000 and $80,000 depending on size and type. A three-season sunroom costs $15,000-$35,000. A four-season sunroom with HVAC costs $40,000-$80,000."}},
      {"@type": "Question", "name": "Do sunrooms require permits in Florida?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. All sunroom and Florida room additions require building permits in Florida. Hawley Construction handles all permit applications and inspections."}},
      {"@type": "Question", "name": "Will a sunroom increase my home value?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. Sunrooms typically return 50-70% of their cost in added home value in Florida, where year-round outdoor living is highly desirable."}}
    ]
  }
];
const IMG = "https://d2xsxph8kpxj0f.cloudfront.net/310519663540279873/mqBaZEe8cowVKqLebSdcGQ/hawley-sunroom-screened-TouYoyDabjd4tNaeYJgTRx.webp";
const faqs = [
  { q: "How much does a sunroom cost in Florida?", a: "A sunroom addition in Florida costs between $25,000 and $80,000 depending on size and type. A three-season sunroom costs $15,000-$35,000. A four-season sunroom with HVAC costs $40,000-$80,000." },
  { q: "What is the difference between a sunroom and a Florida room?", a: "A Florida room is typically a screened or glass-enclosed porch that is not climate-controlled. A sunroom is a fully insulated, climate-controlled addition with HVAC." },
  { q: "Do sunrooms require permits in Florida?", a: "Yes. All sunroom and Florida room additions require building permits in Florida. Hawley Construction handles all permit applications and inspections." },
  { q: "How long does it take to build a sunroom?", a: "A standard sunroom addition takes 6-12 weeks from permit approval to completion. The timeline depends on size, complexity, and whether HVAC is included." },
  { q: "Will a sunroom increase my home value?", a: "Yes. Sunrooms typically return 50-70% of their cost in added home value in Florida, where year-round outdoor living is highly desirable." },
];
const benefits = ["Three-season and four-season options", "Energy-efficient insulated glass systems", "HVAC integration for year-round comfort", "Custom flooring and ceiling options", "Electrical and lighting installation", "Seamless transition from interior", "Screened enclosure options", "Permit handling included"];
---
<Layout
  title="Sunroom and Florida Room Contractor Tampa Bay | Hawley Construction Co."
  description="Sunroom and Florida room additions in Tampa Bay. Three-season and four-season sunrooms, screened enclosures. Licensed and insured. Free estimates. Call (704) 619-1480."
  canonical="https://hawleyconstruction.co/sunroom-florida-room-contractor/"
  schema={schemaData}
  ogImage={IMG}
>
  <Navbar />
  <section class="relative pt-28 pb-20 md:pt-36 md:pb-28" style="background-color:var(--navy);">
    <div class="absolute inset-0 overflow-hidden">
      <img src={IMG} alt="Sunroom Florida room contractor Tampa Bay" class="w-full h-full object-cover opacity-35" loading="eager" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <nav class="flex items-center gap-2 text-xs mb-6" style="color:rgba(255,255,255,0.6);font-family:'DM Sans',sans-serif;" aria-label="Breadcrumb">
          <a href="/" style="color:rgba(255,255,255,0.6);">Home</a><span>/</span>
          <a href="/services" style="color:rgba(255,255,255,0.6);">Services</a><span>/</span>
          <span style="color:var(--gold);">Sunroom Contractor</span>
        </nav>
        <span class="text-xs font-semibold uppercase tracking-[0.2em] mb-3 block" style="color:var(--gold);font-family:'DM Sans',sans-serif;">Tampa Bay, FL</span>
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight" style="font-family:'Playfair Display',serif;">Sunroom &amp; Florida Room Contractor Tampa Bay</h1>
        <p class="text-lg mb-8" style="color:rgba(255,255,255,0.8);font-family:'DM Sans',sans-serif;">Bring the Florida sunshine indoors. We build beautiful, energy-efficient sunrooms and Florida rooms that become the most-loved room in your home.</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="btn-gold text-center">Get Free Estimate</a>
          <a href="tel:7046191480" class="btn-outline-light text-center">Call (704) 619-1480</a>
        </div>
      </div>
    </div>
  </section>
  <section class="py-16 md:py-24" style="background-color:var(--cream);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <span class="section-divider"></span>
          <h2 class="text-3xl font-bold mb-6" style="color:var(--navy2);">Tampa Bay Sunroom and Florida Room Experts</h2>
          <p class="text-base leading-relaxed mb-6" style="color:var(--muted);font-family:'DM Sans',sans-serif;">Hawley Construction Co. designs and builds sunrooms and Florida rooms throughout Tampa Bay. Whether you want a screened three-season porch or a fully insulated, climate-controlled four-season sunroom, we handle the entire project from design and permits to construction and finishing.</p>
          <h3 class="text-2xl font-bold mb-4" style="color:var(--navy2);">What Is Included</h3>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10">
            {benefits.map(b => (
              <li class="flex items-start gap-2 text-sm" style="color:var(--muted);font-family:'DM Sans',sans-serif;">
                <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 mt-1.5" style="background-color:var(--gold);display:inline-block;"></span>
                {b}
              </li>
            ))}
          </ul>
          <h3 class="text-2xl font-bold mb-4" style="color:var(--navy2);">Frequently Asked Questions</h3>
          <div class="mb-10">
            {faqs.map((item, i) => (
              <div class="border-b py-5" style="border-color:oklch(0.88 0.01 250);">
                <button class="faq-btn w-full text-left flex items-center justify-between gap-4" data-idx={i}>
                  <span class="text-base font-semibold" style="color:var(--navy2);font-family:'DM Sans',sans-serif;">{item.q}</span>
                  <span class="text-xl font-light flex-shrink-0" style="color:var(--gold);">+</span>
                </button>
                <div class="faq-answer hidden mt-3">
                  <p class="text-sm leading-relaxed" style="color:var(--muted);font-family:'DM Sans',sans-serif;">{item.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="lg:col-span-1">
          <div class="bg-white p-8 shadow-sm sticky top-24" style="border-radius:2px;">
            <h2 class="text-xl font-bold mb-2" style="color:var(--navy2);">Get a Free Estimate</h2>
            <p class="text-sm mb-6" style="color:var(--muted);font-family:'DM Sans',sans-serif;">We respond within 24 hours. No obligation.</p>
            <form id="seo-form" action="https://formspree.io/f/xredrbrg" method="POST" class="flex flex-col gap-4">
              <input type="hidden" name="service" value="Sunroom / Florida Room" />
              <input class="form-input" type="text" name="name" placeholder="Your Name" required />
              <input class="form-input" type="email" name="email" placeholder="Email Address" required />
              <input class="form-input" type="tel" name="phone" placeholder="Phone Number" />
              <textarea class="form-input" name="message" rows="4" placeholder="Describe your project..."></textarea>
              <button type="submit" class="btn-gold w-full text-center">Send Message</button>
            </form>
            <p id="form-success" class="hidden text-sm mt-4 text-center font-semibold" style="color:oklch(0.55 0.15 145);">Thank you! We will be in touch within 24 hours.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="py-16" style="background-color:var(--navy);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4" style="font-family:'Playfair Display',serif;">Ready to Add a Sunroom?</h2>
      <p class="mb-8" style="color:rgba(255,255,255,0.7);font-family:'DM Sans',sans-serif;">Call us or request a free estimate online. Serving Tampa, St. Petersburg, Clearwater, and all of Tampa Bay.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn-gold text-center">Get Free Estimate</a>
        <a href="tel:7046191480" class="btn-outline-light text-center">Call (704) 619-1480</a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
<script>
document.getElementById('seo-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const form = e.target as HTMLFormElement;
  const data = new FormData(form);
  const res = await fetch(form.action, { method: 'POST', body: data, headers: { 'Accept': 'application/json' } });
  if (res.ok) {
    form.style.display = 'none';
    document.getElementById('form-success')?.classList.remove('hidden');
    if (typeof gtag !== 'undefined') {
      gtag('event', 'conversion', { 'send_to': 'AW-18172396876/cPy9CKLmgrQcEMyKo91D', 'value': 100.0, 'currency': 'USD' });
      gtag('event', 'generate_lead', { 'currency': 'USD', 'value': 100.0 });
    }
  }
});
document.querySelectorAll('.faq-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const answer = btn.nextElementSibling as HTMLElement;
    const icon = btn.querySelector('span:last-child') as HTMLElement;
    const isOpen = !answer.classList.contains('hidden');
    answer.classList.toggle('hidden', isOpen);
    icon.textContent = isOpen ? '+' : '\u2212';
  });
});
</script>
